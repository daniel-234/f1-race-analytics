# Local development only. The deployed app (app.py) does not use these.
# Copy to .env if you want to run the live replay dashboard (`uv run live`).

# Live data source for the replay dashboard.
#   fake       — in-memory race simulator (default, works out of the box)
#   sportmonks — real live data (not yet implemented, will fail)
DATA_SOURCE=fake

# Add it if you want to use the Sportmonks API
SPORTMONKS_API_TOKEN=

# Artificial per-call delay for the fake data source, in milliseconds.
# Lower = faster simulation, higher = closer to a real API's latency.
FAKE_DELAY_MS=100

# URL of the live API for the replay dashboard.
# Unset in production until the live API is co-deployed; this hides the
# replay nav link and 404s the /replay route. Set locally to point at
# `uv run live`.
REPLAY_URL=
